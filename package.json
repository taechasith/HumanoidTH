  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:next": "next dev",
    "seed:watch": "tsx scripts/watch-seed.ts",
